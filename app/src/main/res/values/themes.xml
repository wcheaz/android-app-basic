<resources>
    <style name="Theme.BasicApp" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:statusBarColor">@color/purple_700</item>
    </style>

    <style name="Theme.BasicApp.Noir" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/pure_white</item>
        <item name="colorPrimaryVariant">@color/silver</item>
        <item name="colorOnPrimary">@color/true_black</item>
        <item name="colorSecondary">@color/signal_red</item>
        <item name="colorSecondaryVariant">@color/signal_dim</item>
        <item name="colorOnSecondary">@color/pure_white</item>
        <item name="android:windowBackground">@color/true_black</item>
        <item name="android:statusBarColor">@color/true_black</item>
        <item name="android:navigationBarColor">@color/true_black</item>
        <item name="android:textColor">@color/pure_white</item>
    </style>
</resources>
