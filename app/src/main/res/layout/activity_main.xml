<?xml version="1.0" encoding="utf-8"?>

<!-- ConstraintLayout is the root container. It positions its children using constraints
     (rules like "align this element's left edge to the parent's left edge") rather than
     stacking them linearly. This gives flexible, responsive layouts.

     xmlns lines declare XML namespaces, which act like prefixes:
       android: = built-in Android attributes (width, height, text, etc.)
       app: = library-specific attributes (like ConstraintLayout constraints)
       tools: = design-time-only hints for Android Studio's layout preview

     layout_width and layout_height = "match_parent" means this layout stretches to fill the entire screen.

     tools:context tells Android Studio's preview which Activity this layout belongs to,
       so it can render a more accurate preview. It is removed from the final APK. -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <Button
        android:id="@+id/buttonNavigateToCircle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Circle Page"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- TextView displays read-only text on screen.
         id = @+id/textView creates an ID so we can reference this element from Kotlin
           code using findViewById(R.id.textView). The + means "create this ID if it doesn't exist".
         layout_width/height = "wrap_content" means the view sizes itself to fit its content (the text).
           Horizontally it will be exactly as wide as the text needs, vertically as tall as textSize needs.
         text = "Hello World!" is the default text shown when the screen first appears.
         textSize = "24sp" uses scale-independent pixels, which scale with the user's font size
           setting in their device preferences, making text accessible. 24sp is large.

         Constraint positioning:
           constraintBottom_toTopOf = pins the bottom of textView to the top of the button.
           constraintEnd_toEndOf = "parent" pins the right edge to the parent's right edge.
           constraintStart_toStartOf = "parent" pins the left edge to the parent's left edge.
             Together, End_toEndOf + Start_toStartOf centers the textView horizontally.
           constraintTop_toTopOf = "parent" pins the top to the top of the screen.
             Combined with Bottom_toTopOf, this stretches textView between the screen top and the button.
           constraintVertical_chainStyle = "packed" means the chain elements (textView + button)
             are grouped tightly together in the center rather than spread apart evenly. -->
    <TextView
        android:id="@+id/textView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Hello World!"
        android:textSize="24sp"
        app:layout_constraintBottom_toTopOf="@+id/button"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />

    <!-- Button is a tappable UI element that triggers an action when pressed.
         id = @+id/button creates an ID so we can find this button from Kotlin code.
         layout_width/height = "wrap_content" sizes the button to fit its label text ("Tap Me").
         text = "Tap Me" is the label displayed on the button.
         layout_marginTop = "24dp" adds 24 density-independent pixels of space above the button
           (between it and the textView). dp scales across different screen densities.

         Constraint positioning:
           constraintBottom_toBottomOf = "parent" pins the bottom of the button to the bottom of the screen.
           constraintEnd_toEndOf = "parent" pins the right edge to the parent's right edge.
           constraintStart_toStartOf = "parent" pins the left edge to the parent's left edge.
             Together, End_toEndOf + Start_toStartOf centers the button horizontally.
           constraintTop_toBottomOf = pins the top of the button to the bottom of the textView.
             This completes the vertical chain: parent top -> textView -> button -> parent bottom. -->
    <Button
        android:id="@+id/button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tap Me"
        android:layout_marginTop="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView" />

</androidx.constraintlayout.widget.ConstraintLayout>
